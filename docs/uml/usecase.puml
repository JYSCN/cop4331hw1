@startuml usecase

title Colors App — Use Case Diagram

left to right direction

actor "Guest" as Guest
actor "Registered User" as User

rectangle "Colors Application" {
  usecase "Register Account" as UC1
  usecase "Log In" as UC2
  usecase "Log Out" as UC3
  usecase "View Colors" as UC4
  usecase "Add Color" as UC5
  usecase "Delete Color" as UC6
}

Guest --> UC1
Guest --> UC2

User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6

UC4 ..> UC2 : <<include>>
UC5 ..> UC2 : <<include>>
UC6 ..> UC2 : <<include>>

@enduml
